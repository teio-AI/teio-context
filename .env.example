# Neon (use the POOLED connection string / serverless driver — ARCHITECTURE §6)
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/teio_context?sslmode=require"

# GitHub App (the bot identity + ruleset bypass actor — ARCHITECTURE §6)
GITHUB_APP_ID="123456"
# PEM contents; literal \n allowed (converted at load) or a real multiline value
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# The paid org (Team/Enterprise) that owns space repos — ARCHITECTURE §7.1
GITHUB_ORG="teio"
GITHUB_WEBHOOK_SECRET="set-in-phase-5"

# Clerk (reuse TEIO's instance)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Space creation (POST /api/spaces) is staff-only — comma-separated Clerk user ids
STAFF_USER_IDS="user_abc123"

# --- mcp/server.ts (a separate process, run with `npm run mcp`) ---
# Base URL of the deployed teio-context service.
TEIO_CONTEXT_API_URL="https://context.teio.ai"
# A per-space machine token (tctx_<slug>_...), issued via POST /api/spaces/:id/tokens (Phase 3+).
TEIO_CONTEXT_TOKEN="tctx_acme_..."
