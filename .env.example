# Neon (use the POOLED connection string / serverless driver — ARCHITECTURE §6)
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/teio_context?sslmode=require"

# GitHub App (the bot identity + ruleset bypass actor — ARCHITECTURE §6)
GITHUB_APP_ID="123456"
# PEM contents; literal \n allowed (converted at load) or a real multiline value
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# The account that owns space repos — ARCHITECTURE §7.1
GITHUB_ORG="teio"
# Dev mode (no paid org yet): run on a personal account with PUBLIC repos so
# rulesets are free. Prod defaults are org + private (omit these two).
#   GITHUB_OWNER_TYPE="user"        # 'org' (default) | 'user'
#   GITHUB_REPO_VISIBILITY="public" # 'private' (default) | 'public'  ⚠ public = world-readable context
# Free-tier escape hatch: create PRIVATE repos WITHOUT branch protection when the
# org is on GitHub Free (rulesets 403). Off by default — provisioning fails loud
# rather than silently leaving a space unprotected. Set to "true" to opt in.
#   GITHUB_ALLOW_UNPROTECTED="true"
# Webhook HMAC secret — must match the GitHub App's webhook secret (push + pull_request)
GITHUB_WEBHOOK_SECRET="a-long-random-string"

# Backfill cron (vercel.json runs /api/cron/backfill every 10 min). Vercel sends
# this automatically as `Authorization: Bearer $CRON_SECRET` when set in the env.
CRON_SECRET="a-long-random-string"

# Clerk (reuse TEIO's instance)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Global owners (create + see + administer EVERY space). Two ways to grant it:
#   STAFF_USER_IDS — comma-separated Clerk user ids
#   STAFF_EMAILS   — comma-separated emails; pre-authorize before the person signs
#                    up. On login the verified email is materialized into the
#                    global_owners table (migration 0007); de-listing revokes it.
STAFF_USER_IDS="user_abc123"
STAFF_EMAILS="alice@example.com,bob@example.com"

# --- MCP ---
# The hosted MCP endpoint (app/api/[transport]/route.ts → /api/mcp) needs NO extra
# env — it's part of the Next app. Clients auth two ways: a personal Bearer token
# (tctx_…, generated in Settings) for the Claude Code plugin/terminal, or Clerk
# OAuth "individual sign-in" for the claude.ai / desktop connector.
#
# The optional local stdio server (mcp/server.ts, `bun run mcp`) is legacy — only
# needed for a local process. It reads:
#   TEIO_CONTEXT_API_URL="https://teio-context.vercel.app"
#   TEIO_CONTEXT_TOKEN="tctx_..."   # a personal token (Settings → Personal access token)
